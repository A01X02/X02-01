# ============================================================
# 国内镜像环境变量模板（CloudBase 云托管 + 国内 Supabase）
# ------------------------------------------------------------
# 用法：
#   1. 复制本文件为 .env.local（本地调试）或
#      在 CloudBase 云托管「构建/运行环境变量」中逐项填写
#   2. 把下面所有 your_xxx 替换成你国内环境的真实值
#   3. 与境外 .env.local 完全独立，互不影响
# ============================================================

# 部署环境标识：国内填 domestic（触发 standalone 构建 / 国内图片域名）
NEXT_PUBLIC_DEPLOY_ENV=domestic

# ---- 国内 Supabase（需自建，见 docs/deploy-domestic.md）----
# 注意：必须是纯域名，不要带 /rest/v1 后缀（代码会自动归一化）
NEXT_PUBLIC_SUPABASE_URL=https://your-domestic-supabase.example.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_domestic_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_domestic_service_role_key

# ---- 豆包 seed（国内服务，volces.com，直接复用即可）----
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=your_doubao_model_id

# ---- 火山引擎 TTS 语音（国内服务，直接复用即可）----
VOLC_TTS_ACCESS_TOKEN=your_volc_tts_access_token
VOLC_TTS_APPID=your_volc_tts_appid
VOLC_TTS_CLUSTER=your_volc_tts_cluster
VOLC_TTS_VOICE_ID=your_volc_tts_voice_id

# ---- 背景图（Unsplash，国内可访问；也可留空）----
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ---- 国内站点地址（PWA / 回调用，部署后填 CloudBase 分配的域名）----
NEXT_PUBLIC_SITE_URL=https://your-domestic-app.example.com
