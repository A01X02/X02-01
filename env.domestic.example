# ============================================================
# 国内镜像环境变量模板（腾讯云 CloudBase PG 免费版）
# ------------------------------------------------------------
# 用法：
#   1. 复制本文件为 .env.local（本地调试）或
#      在 CloudBase 云托管「构建/运行环境变量」中逐项填写
#   2. 把下面所有 your_xxx 替换成你 CloudBase 环境的真实值
#   3. 与境外 .env.local 完全独立，互不影响
#
# 获取方式（控制台 tcb.cloud.tencent.com → 环境 x02-01）：
#   - ENV_ID：环境概览页顶部「环境 ID」= x02-01
#   - Publishable Key（前端）：设置 → API Key 配置 → 生成「Publishable Key」
#   - 服务端 API Key（后端）：同一页面生成的「服务端 Key」→ 填到 CLOUDBASE_APIKEY
# ============================================================

# 部署环境标识：国内填 domestic（触发 CloudBase 适配层 + standalone 构建）
NEXT_PUBLIC_DEPLOY_ENV=domestic

# ---- 腾讯云 CloudBase PG（替代 Supabase，免费体验版 6 个月）----
# 环境 ID：x02-01（上海 ap-shanghai）
NEXT_PUBLIC_CLOUDBASE_ENV_ID=x02-01
# 地域：必须与 x02-01 实际地域一致（上海）
NEXT_PUBLIC_CLOUDBASE_REGION=ap-shanghai

# Publishable Key（前端用，等价于 Supabase 的 anon key，可暴露在浏览器）
# 控制台 → 设置 → API Key 配置 → Publishable Key
NEXT_PUBLIC_CLOUDBASE_ACCESS_KEY=your_publishable_key_here

# 服务端 API Key（仅服务端用，等价于 Supabase 的 service_role key，BYPASS RLS）
# 控制台 → 设置 → API Key 配置 → 服务端 Key
# ⚠️ 不要提交到 Git！不要加 NEXT_PUBLIC_ 前缀！
# 适配层会自动读取本变量名（CLOUDBASE_APIKEY）作为管理员权限
CLOUDBASE_APIKEY=your_server_api_key_here

# ---- 以下变量与境外版完全相同，直接复用 ----

# 豆包 seed（国内服务，volces.com）
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL_ID=your_doubao_model_id

# 火山引擎 TTS 语音（国内服务）
VOLC_TTS_ACCESS_TOKEN=your_volc_tts_access_token
VOLC_TTS_APPID=your_volc_tts_appid
VOLC_TTS_CLUSTER=your_volc_tts_cluster
VOLC_TTS_VOICE_ID=your_volc_tts_voice_id

# 背景图（Unsplash，国内可访问；也可留空）
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# 国内站点地址（PWA / 回调用，部署后填 CloudBase 分配的域名或你的 aeromaxx.ltd）
NEXT_PUBLIC_SITE_URL=https://aeromaxx.ltd
